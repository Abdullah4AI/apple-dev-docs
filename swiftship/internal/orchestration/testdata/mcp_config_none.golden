{
  "mcpServers": {
    "apple-docs": {
      "args": [
        "-y",
        "@kimsungwhee/apple-docs-mcp"
      ],
      "command": "npx"
    },
    "nanowave-tools": {
      "args": [
        "mcp",
        "tools"
      ],
      "command": "nanowave"
    },
    "xcodegen": {
      "args": [
        "mcp",
        "xcodegen"
      ],
      "command": "nanowave"
    }
  }
}
